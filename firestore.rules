rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is this the specific user's data?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default: Deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: Property Inspections
    match /inspections/{inspectionId} {
      // For now, let's allow you (authenticated) to do everything
      allow read, write: if isSignedIn();
    }

    // Collection: Receivables / Finances
    match /receivables/{document=**} {
      // Only YOU should see the money talk
      // We can lock this down to your specific UID later
      allow read, write: if isSignedIn();
    }
  }
}
