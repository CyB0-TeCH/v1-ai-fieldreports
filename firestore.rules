rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Logic: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Logic: Does the UID match the document?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection: Property Inspections
    // Allow any logged-in team member to read/write for now
    match /inspections/{inspectionId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Receivables / Finances
    // This is locked down to specific owners
    match /receivables/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
